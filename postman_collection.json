{
  "info": {
    "name": "CS6 - Port 3001",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Autentikasi & Manajemen Pengguna",
      "item": [
        {
          "name": "1.1. POST /user/register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"username\": \"johndoe\",\n  \"email\": \"john@example.com\",\n  \"phone\": \"+1-555-0100\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": "http://localhost:3001/user/register"
          }
        },
        {
          "name": "1.2. POST /user/login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": "http://localhost:3001/user/login"
          }
        },
        {
          "name": "1.3. POST /auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.payload.token) {",
                  "    pm.collectionVariables.set(\"token\", jsonData.payload.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": "http://localhost:3001/auth/login"
          }
        },
        {
          "name": "1.4. PUT /user/update",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 1,\n  \"name\": \"John Updated\",\n  \"username\": \"johnupdated\",\n  \"email\": \"john.updated@example.com\",\n  \"phone\": \"+1-555-0101\",\n  \"password\": \"NewSecurePass456!\",\n  \"balance\": 1000\n}"
            },
            "url": "http://localhost:3001/user/update"
          }
        },
        {
          "name": "1.5. GET /user/history",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "http://localhost:3001/user/history"
          }
        },
        {
          "name": "1.6. GET /user/total-spent",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "http://localhost:3001/user/total-spent"
          }
        }
      ]
    },
    {
      "name": "2. Item",
      "item": [
        {
          "name": "2.1. GET /items",
          "request": {
            "method": "GET",
            "url": "http://localhost:3001/items"
          }
        }
      ]
    },
    {
      "name": "3. Transaksi",
      "item": [
        {
          "name": "3.1. POST /transaction/create",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": 1,\n  \"item_id\": 2,\n  \"quantity\": 3,\n  \"description\": \"Beli laptop untuk kerja\"\n}"
            },
            "url": "http://localhost:3001/transaction/create"
          }
        },
        {
          "name": "3.2. GET /transaction/:id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "http://localhost:3001/transaction/6"
          }
        },
        {
          "name": "3.3. POST /transaction/pay/:id",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "http://localhost:3001/transaction/pay/6"
          }
        },
        {
          "name": "3.4. DELETE /transaction/:id",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "http://localhost:3001/transaction/6"
          }
        }
      ]
    },
    {
      "name": "6. Endpoint Laporan",
      "item": [
        {
          "name": "6.1. GET /reports/top-users",
          "request": {
            "method": "GET",
            "url": "http://localhost:3001/reports/top-users?limit=10"
          }
        },
        {
          "name": "6.2. GET /reports/items-sold",
          "request": {
            "method": "GET",
            "url": "http://localhost:3001/reports/items-sold"
          }
        },
        {
          "name": "6.3. GET /reports/monthly-sales",
          "request": {
            "method": "GET",
            "url": "http://localhost:3001/reports/monthly-sales?year=2026"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "token",
      "value": ""
    }
  ]
}