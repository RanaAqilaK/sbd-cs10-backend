PORT=3001
NODE_ENV=development

# Database Configuration
DB_USER=postgres
DB_HOST=localhost
DB_NAME=sbd_store
DB_PASSWORD=yourpassword
DB_PORT=5432
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/sbd_db

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_complex

# CORS Configuration
# For local development: http://localhost:3000
# For Vercel: https://your-frontend.vercel.app
CORS_ORIGIN=http://localhost:3000

# Vercel Automatic Detection
# Leave VERCEL_URL empty locally, it will be auto-set by Vercel in production
VERCEL_URL=