PORT=3001
NODE_ENV=development

# Database Configuration
# Option 1: Local PostgreSQL (development)
DB_USER=postgres
DB_HOST=localhost
DB_NAME=sbd_store
DB_PASSWORD=yourpassword
DB_PORT=5432

# Option 2: Neon Cloud Database (production)
# Uncomment and set DATABASE_URL for Neon, comment out DB_* vars above
# DATABASE_URL=postgresql://username:password@ep-your-project.us-east-1.neon.tech/sbd_store?sslmode=require

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_complex

# CORS Configuration
CORS_ORIGIN=http://localhost:3000